# Copia para `.env` (local) e define as mesmas chaves no painel da Vercel (Produção).

# --- Frontend (Vite) — só variáveis com prefixo VITE_ são expostas ao browser ---
# Ativa o envio para a API ao concluir uma reserva (site ou painel).
VITE_ENABLE_RESERVATION_API=true
# Com DATABASE_URL + `npm run dev:vercel`: carrega suites/reviews/conteúdo/score do MySQL (GET /api/site-data).
# Escritas no painel requerem SESSION_SECRET + JWT (login devolve `token`).
VITE_ENABLE_SITE_DATA_API=
# Se o front estiver noutro domínio que a API, define a base, ex.: https://o-teu-site.vercel.app
# Deixa vazio se site + API estão no mesmo domínio (recomendado).
VITE_API_BASE_URL=
# Opcional: o mesmo valor que RESERVATION_INGEST_SECRET no servidor (protege o endpoint).
VITE_RESERVATION_INGEST_SECRET=

# --- API serverless (Vercel) — NÃO uses prefixo VITE_; nunca commits com valores reais ---

# MySQL (migração em curso) — connection string; servidor apenas.
# Ex.: mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL=
# Opcional: limite de ligações no pool (predefinição 5, máx. 10 no código)
DATABASE_POOL_LIMIT=5
# Opcional: força SSL (ou usa parâmetros ssl na própria URL)
DATABASE_SSL=
# Opcional: com SSL, rejeitar certificados não confiáveis (predefinição: true)
DATABASE_SSL_REJECT_UNAUTHORIZED=
# Opcional: se definido, GET /api/health/db exige Authorization: Bearer <valor> ou header X-Health-Secret
DATABASE_HEALTH_SECRET=
# Aplicar migrações SQL (requer DATABASE_URL): npm run db:migrate
# Criar utilizador admin na base (bcrypt): npm run db:seed-admin -- user password superadmin
# Testar se a password bate com o hash na base: npm run db:verify-admin -- user password

# JWT para sessão admin (opcional; ≥16 caracteres). Se definido, /api/admin-login devolve `token` no JSON.
SESSION_SECRET=

# Alternativa ao seed: ADMIN_SEED_USERNAME / ADMIN_SEED_PASSWORD / ADMIN_SEED_ROLE para `npm run db:seed-admin` sem argumentos

# Supabase: Project Settings → API → URL + service_role (secreta)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend: https://resend.com — API Key + e-mail que recebe alertas
RESEND_API_KEY=
NOTIFY_EMAIL=recepcao@teudominio.pt
# Remetente (domínio verificado na Resend, ou onboarding@resend.dev para testes)
RESEND_FROM_EMAIL=Palacium Reservas <onboarding@resend.dev>

# Opcional: se definido, o cliente tem de enviar header X-Reservation-Secret com o mesmo valor
RESERVATION_INGEST_SECRET=

# Admin login — Área Reservada (server-side only; never commit real values).
# JSON array, one line. Roles: superadmin | admin | viewer
# Example (replace passwords before use):
# [{"username":"design","password":"CHANGE_ME_STRONG","role":"superadmin"}]
#
# Local: use `npm run dev:vercel` for site + /api. Plain `npm run dev` is Vite only (no /api).
# so `api/admin-login.ts` loads and reads ADMIN_USERS_JSON from this file.
# First time: `npx vercel login` / `npx vercel link` if prompted.
ADMIN_USERS_JSON=

# Opcional: hints no login (wrong_password vs unknown_user). Em `vercel dev` também ativo se VERCEL_ENV=development.
ADMIN_LOGIN_DEBUG=

# Gemini (já usado no admin)
GEMINI_API_KEY=
